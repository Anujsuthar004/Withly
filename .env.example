# Server
PORT=8787
APP_ENV=development

# Storage: json | postgres
# If DATABASE_URL is set, postgres is used unless STORAGE_DRIVER is explicitly set to json
STORAGE_DRIVER=postgres
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
PGSSL=enable

# Auth
AUTH_REQUIRED=true
TOKEN_SECRET=replace-with-long-random-secret
TOKEN_TTL_SECONDS=604800
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
BOOTSTRAP_ADMIN_EMAIL=you@example.com
VERIFICATION_CODE_TTL_MS=1800000
PASSWORD_RESET_CODE_TTL_MS=1200000
EXPOSE_DEV_AUTH_CODES=false

# Transactional email
# local: EMAIL_PROVIDER=console
# production: use resend | postmark | sendgrid
EMAIL_PROVIDER=console
EMAIL_FROM=Tag Along <no-reply@example.com>
RESEND_API_KEY=
POSTMARK_SERVER_TOKEN=
SENDGRID_API_KEY=

# Abuse protection
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=40
